# Ejemplo de archivo .env para SistemaLeos
# Copia este archivo a .env y ajusta los valores según tu entorno

# Aplicación
APP_NAME=SistemaLeos
APP_ENV=local
APP_KEY=base64:ReplaceWithYourKey
APP_DEBUG=true
APP_URL=http://localhost

# Base de datos
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret

# Cache / Sessions
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="SistemaLeos"

# Opcionales
LOG_CHANNEL=stack

# Vite / Supabase
VITE_SUPABASE_URL=https://pxflurcdfdaycrczmovd.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_u9D69uR10PVrtNOrCy5nDg__1bqeICv